{
  "expo": {
    "name": "QuakeLink",
    "slug": "quakelink",
    "version": "1.0.0",
    "scheme": "quakelink",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quakelink.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "QuakeLink shares your GPS location over the mesh network when you trigger an emergency alert.",
        "NSMotionUsageDescription": "QuakeLink uses motion sensors to detect seismic activity.",
        "NSBluetoothAlwaysUsageDescription": "QuakeLink uses Bluetooth to connect with nearby devices for mesh messaging.",
        "NSBluetoothPeripheralUsageDescription": "QuakeLink uses Bluetooth to connect with nearby devices for mesh messaging."
      }
    },
    "android": {
      "package": "com.quakelink.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "BODY_SENSORS"
      ]
    },
    "plugins": [
      "./plugins/withMonorepoAutolinking",
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "16.0" },
          "android": { "minSdkVersion": 26 }
        }
      ]
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    }
  }
}
